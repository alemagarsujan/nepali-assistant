# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Add it to .gitignore immediately.

PORT=3000

# Single key used for everything: the Gemini Live API (speech in, intent +
# spoken reply out, over the /api/assistant WebSocket turn) and the Gemini
# TTS endpoint (/api/speak). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
