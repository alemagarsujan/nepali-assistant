# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Add it to .gitignore immediately.

PORT=3000

# Speech-to-text provider (Sarvam AI supports Nepali with code-mixing)
SARVAM_API_KEY=

# Text-to-speech provider (pick one)
ELEVENLABS_API_KEY=
NARAKEET_API_KEY=

# LLM for intent interpretation and Q&A
ANTHROPIC_API_KEY=

# A long random string used to sign caregiver pairing codes
PAIRING_SECRET=
