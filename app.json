{
  "expo": {
    "name": "Sahayogi",
    "slug": "sahayogi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "बोलेर कुरा गर्नको लागि माइक्रोफोन चाहिन्छ।",
        "NSContactsUsageDescription": "फोन गर्नको लागि तपाईंको सम्पर्क सूची चाहिन्छ।",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.sahayogi.assistant"
    },
    "android": {
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "READ_CONTACTS",
        "CALL_PHONE",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.sahayogi.assistant"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "48e890b9-f6f0-4df5-942b-b39a3aff7be8"
      }
    }
  }
}
